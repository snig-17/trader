# Copy to ".env" and fill in. Load it before running (e.g. `set -a; . ./.env; set +a`).
# NEVER commit real keys.

# --- Required: Alpaca PAPER keys (free, no deposit) from app.alpaca.markets ---
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here

# --- Mode: PAPER (default, fake money) or LIVE (real money, triple-gated) ------
BOT_MODE=PAPER

# --- Strategy: trend (default) | mean_reversion | breakout --------------------
BOT_STRATEGY=trend

# --- LIVE ONLY. Leave commented for paper. One of the three live gates. -------
# Setting this to YES is a deliberate acknowledgement that real money is at risk.
# I_UNDERSTAND_LIVE_RISK=YES
